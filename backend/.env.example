NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:4200
MONGO_URI=mongodb://localhost:27017/newscape
MONGO_DB=newscape

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

API_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_MAX=20
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MS=900000
PASSWORD_HISTORY_LIMIT=5
PASSWORD_RESET_TTL_MS=900000

AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-me-now
AUTH_ADMIN_PASSWORD_HASH=
AUTH_ADMIN_EMAIL=admin@newscape.local
AUTH_USER_USERNAME=user
AUTH_USER_PASSWORD=change-me-now
AUTH_USER_PASSWORD_HASH=
AUTH_USER_EMAIL=user@newscape.local

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@newscape.local
PASSWORD_RESET_BASE_URL=http://localhost:4200/login

LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true